# ===== DATABASE =====
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/skincare_nepal

# ===== GOOGLE CLOUD (AI Analysis) =====
# Path to your Google Cloud service account JSON key
GOOGLE_CLOUD_CREDENTIALS_PATH=./credentials/google-cloud-key.json

# ===== PAYMENTS =====
# Khalti API Keys (get from khalti.com/settings)
KHALTI_PUBLIC_KEY=your_khalti_public_key_here
KHALTI_SECRET_KEY=your_khalti_secret_key_here

# Stripe API Keys (get from stripe.com/dashboard)
STRIPE_PUBLIC_KEY=your_stripe_public_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ===== JWT AUTHENTICATION =====
# Secret key for signing JWT tokens (use a strong random string)
SECRET_KEY=your_super_secret_key_change_this_in_production_12345

# ===== FIREBASE (Chat) =====
# Firebase service account JSON path
FIREBASE_CREDENTIALS_PATH=./credentials/firebase-key.json

# ===== SERVER =====
# API host and port
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
